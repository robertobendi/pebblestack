{% extends '@admin/layout.twig' %}
{% set active = 'settings' %}
{% set title = 'Settings' %}

{% block content %}
    <div class="topbar">
        <div class="topbar-left">
            <h1>Settings</h1>
            <p>Site identity and your account.</p>
        </div>
    </div>

    <div class="card">
        <div class="card-head">
            <h2>Site</h2>
        </div>
        <div class="card-pad">
            {% if site_errors|length > 0 %}
                <div class="alert alert-error">
                    <ul>{% for e in site_errors %}<li>{{ e }}</li>{% endfor %}</ul>
                </div>
            {% endif %}
            <form method="post" action="/admin/settings/site" class="form-grid">
                {{ csrf_field()|raw }}
                <div class="field">
                    <label for="site_name" class="field-required">Site name</label>
                    <input id="site_name" name="site_name" type="text" value="{{ site_name }}" required>
                    <div class="help">Shown in the browser tab and the public site header.</div>
                </div>
                <div class="button-row">
                    <button type="submit" class="btn btn-primary">Save site</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-head">
            <h2>Change password</h2>
        </div>
        <div class="card-pad">
            {% if password_errors|length > 0 %}
                <div class="alert alert-error">
                    <ul>{% for e in password_errors %}<li>{{ e }}</li>{% endfor %}</ul>
                </div>
            {% endif %}
            <form method="post" action="/admin/settings/password" class="form-grid" autocomplete="off">
                {{ csrf_field()|raw }}
                <div class="field">
                    <label for="current_password" class="field-required">Current password</label>
                    <input id="current_password" name="current_password" type="password" required autocomplete="current-password">
                </div>
                <div class="field">
                    <label for="new_password" class="field-required">New password</label>
                    <input id="new_password" name="new_password" type="password" required minlength="8" autocomplete="new-password">
                </div>
                <div class="field">
                    <label for="new_password_confirm" class="field-required">Confirm new password</label>
                    <input id="new_password_confirm" name="new_password_confirm" type="password" required minlength="8" autocomplete="new-password">
                </div>
                <div class="button-row">
                    <button type="submit" class="btn btn-primary">Update password</button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
