<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ site.name }}{% endblock %}</title>
    {% if meta_description is defined %}
        <meta name="description" content="{{ meta_description }}">
    {% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #faf8f4;
            --surface: #ffffff;
            --ink: #1a1816;
            --ink-soft: #4a4541;
            --muted: #7a7370;
            --hairline: #e8e2d8;
            --accent: #b8431f;
            --accent-soft: #f5e8e1;
            --max: 720px;
        }
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
            background: var(--bg);
            color: var(--ink);
            line-height: 1.65;
            font-size: 17px;
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
        }
        h1, h2, h3, h4 {
            font-family: 'Fraunces', Georgia, 'Times New Roman', serif;
            font-weight: 500;
            letter-spacing: -.015em;
            line-height: 1.15;
            color: var(--ink);
        }
        h1 { font-size: clamp(2rem, 5vw, 3.25rem); margin: 0 0 .5rem; }
        h2 { font-size: 1.875rem; margin: 2.5rem 0 .75rem; }
        h3 { font-size: 1.375rem; margin: 2rem 0 .5rem; }
        p, ul, ol, blockquote { margin: 0 0 1.25em; }
        a { color: var(--accent); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
        a:hover { color: var(--ink); }
        img { max-width: 100%; height: auto; border-radius: 4px; }
        blockquote {
            border-left: 3px solid var(--accent);
            padding: .25rem 0 .25rem 1.25rem;
            color: var(--ink-soft);
            font-style: italic;
            margin-left: 0;
        }
        code {
            background: var(--accent-soft);
            color: var(--accent);
            padding: .125rem .375rem;
            border-radius: 3px;
            font-size: .9em;
            font-family: ui-monospace, "SF Mono", Menlo, monospace;
        }
        pre {
            background: var(--ink);
            color: #f5f0e8;
            padding: 1rem 1.25rem;
            border-radius: 6px;
            overflow-x: auto;
            font-size: .9em;
            line-height: 1.55;
        }
        pre code { background: transparent; color: inherit; padding: 0; }
        hr { border: 0; border-top: 1px solid var(--hairline); margin: 3rem 0; }

        .site-header {
            border-bottom: 1px solid var(--hairline);
            padding: 1.25rem clamp(1rem, 4vw, 2rem);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 2rem;
            flex-wrap: wrap;
            background: var(--surface);
        }
        .site-title {
            font-family: 'Fraunces', Georgia, serif;
            font-weight: 600;
            font-size: 1.25rem;
            letter-spacing: -.01em;
            color: var(--ink);
            text-decoration: none;
        }
        .site-title:hover { color: var(--accent); }
        .site-nav { display: flex; gap: 1.5rem; flex-wrap: wrap; }
        .site-nav a {
            color: var(--ink-soft);
            text-decoration: none;
            font-size: .9375rem;
            font-weight: 500;
        }
        .site-nav a:hover { color: var(--accent); }

        main { padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 4vw, 2rem); }
        .wrap { max-width: var(--max); margin: 0 auto; }
        .wrap-wide { max-width: 960px; margin: 0 auto; }

        .lede { font-size: 1.125rem; color: var(--ink-soft); }
        .meta { font-size: .875rem; color: var(--muted); margin-bottom: 2rem; }
        .meta a { color: var(--muted); }

        .post-card {
            display: block;
            padding: 1.5rem 0;
            border-bottom: 1px solid var(--hairline);
            text-decoration: none;
            color: inherit;
        }
        .post-card:last-child { border-bottom: 0; }
        .post-card h2 { margin: 0 0 .25rem; font-size: 1.5rem; }
        .post-card:hover h2 { color: var(--accent); }
        .post-card .date { font-size: .8125rem; color: var(--muted); }
        .post-card p { margin: .5rem 0 0; color: var(--ink-soft); }

        .site-footer {
            border-top: 1px solid var(--hairline);
            padding: 2rem clamp(1rem, 4vw, 2rem);
            text-align: center;
            color: var(--muted);
            font-size: .8125rem;
            margin-top: 4rem;
        }
        .site-footer a { color: var(--muted); }

        .empty-state { text-align: center; padding: 4rem 0; color: var(--muted); }
        .empty-state h1 { color: var(--ink); }

        .article-body :first-child { margin-top: 0; }
        .article-body img { display: block; margin: 1.5rem auto; }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg: #1a1816; --surface: #221f1c; --ink: #f5f0e8; --ink-soft: #c9c1b6;
                --muted: #918a82; --hairline: #38332d; --accent: #d96a44; --accent-soft: #3a2620;
            }
            pre { background: #0d0c0a; color: #f5f0e8; }
        }
    </style>
    {% block head %}{% endblock %}
</head>
<body>
    <header class="site-header">
        <a class="site-title" href="/">{{ site.name }}</a>
        <nav class="site-nav">
            {% for item in nav() %}
                <a href="{{ item.url }}">{{ item.label }}</a>
            {% endfor %}
        </nav>
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
        <p>© {{ "now"|date('Y') }} {{ site.name }}. Built with <a href="https://github.com/" rel="noopener">Pebblestack</a>.</p>
    </footer>
</body>
</html>
