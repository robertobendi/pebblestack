{% extends '@admin/layout.twig' %}
{% set active = 'media' %}
{% set title = 'Media' %}

{% block content %}
    <div class="topbar">
        <div class="topbar-left">
            <h1>Media</h1>
            <p>{{ items|length }} {{ items|length == 1 ? 'file' : 'files' }} · upload up to {{ max_mb }} MB · {{ allowed_ext|join(', ') }}</p>
        </div>
    </div>

    {% if errors|length > 0 %}
        <div class="alert alert-error">
            <ul>{% for e in errors %}<li>{{ e }}</li>{% endfor %}</ul>
        </div>
    {% endif %}

    <div class="card">
        <div class="card-pad">
            <form method="post" action="/admin/media" enctype="multipart/form-data" class="upload-form">
                {{ csrf_field()|raw }}
                <label for="file" class="upload-drop">
                    <strong>Choose a file</strong> or drag it here.
                    <span class="muted">Image (jpg, png, gif, webp, svg) or PDF · max {{ max_mb }} MB</span>
                </label>
                <input id="file" name="file" type="file" required
                       accept="image/jpeg,image/png,image/gif,image/webp,image/svg+xml,application/pdf"
                       onchange="this.form.submit()">
            </form>
        </div>
    </div>

    {% if items|length == 0 %}
        <div class="card">
            <div class="empty">
                <h2>No media yet.</h2>
                <p>Upload your first file using the form above.</p>
            </div>
        </div>
    {% else %}
        <div class="media-grid">
            {% for m in items %}
                <a class="media-tile" href="/admin/media/{{ m.id }}" title="{{ m.originalName }}">
                    {% if m.isImage() %}
                        <span class="media-thumb"
                              style="background-image:url('{{ m.path }}')"
                              role="img"
                              aria-label="{{ m.alt|default(m.originalName) }}"></span>
                    {% else %}
                        <span class="media-thumb media-thumb-doc">PDF</span>
                    {% endif %}
                    <span class="media-name">{{ m.originalName }}</span>
                    <span class="media-meta">
                        {{ m.humanSize() }}
                        {% if m.width %} · {{ m.width }}×{{ m.height }}{% endif %}
                    </span>
                </a>
            {% endfor %}
        </div>
    {% endif %}

    <style>
        .upload-form { position: relative; }
        .upload-form input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
        .upload-drop {
            display: block;
            padding: 2rem 1rem;
            border: 2px dashed var(--border-strong);
            border-radius: 10px;
            text-align: center;
            color: var(--muted);
            cursor: pointer;
        }
        .upload-drop strong { color: var(--accent); }
        .upload-drop .muted { display: block; font-size: .8125rem; margin-top: .25rem; }
        .upload-drop:hover { border-color: var(--accent); background: var(--accent-soft); }

        .media-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 1rem; margin-top: 1.5rem;
        }
        .media-tile {
            display: flex; flex-direction: column;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            text-decoration: none;
            color: var(--text);
            box-shadow: var(--shadow);
            transition: transform .1s, box-shadow .1s;
        }
        .media-tile:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(28,25,23,.08); }
        .media-thumb {
            display: block;
            aspect-ratio: 1 / 1;
            background-size: cover;
            background-position: center;
            background-color: #f5f5f4;
            border-bottom: 1px solid var(--border);
        }
        .media-thumb-doc {
            display: flex; align-items: center; justify-content: center;
            font-family: 'Fraunces', serif; font-size: 1.5rem;
            color: var(--muted); background: var(--accent-soft);
        }
        .media-name { padding: .5rem .75rem 0; font-size: .8125rem; font-weight: 500; word-break: break-all; line-height: 1.3; }
        .media-meta { padding: 0 .75rem .625rem; font-size: .75rem; color: var(--muted); margin-top: .125rem; }
    </style>
{% endblock %}
