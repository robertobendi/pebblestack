<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <title>Sign in · {{ site_name }}</title>
    <style>
        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
               background: #fafaf9; color: #1c1917; min-height: 100vh; display: grid; place-items: center; padding: 2rem 1rem; }
        .wrap { width: 100%; max-width: 380px; }
        .brand { display: flex; align-items: center; gap: .625rem; margin-bottom: 1.5rem; justify-content: center; }
        .brand-mark { width: 32px; height: 32px; border-radius: 9px; background: linear-gradient(135deg, #44403c, #1c1917); position: relative; }
        .brand-mark::after { content:''; position: absolute; inset: 7px; border-radius: 4px; background: linear-gradient(135deg, #fafaf9, #d6d3d1); }
        .brand-name { font-weight: 600; }
        .card { background: #fff; border: 1px solid #e7e5e4; border-radius: 12px; padding: 2rem;
                box-shadow: 0 1px 2px rgba(28,25,23,.04), 0 1px 3px rgba(28,25,23,.06); }
        h1 { margin: 0 0 1.25rem; font-size: 1.25rem; }
        .field { margin-bottom: 1rem; }
        .field label { display: block; font-weight: 500; margin-bottom: .25rem; font-size: .875rem; }
        .field input { width: 100%; padding: .5rem .625rem; font: inherit; border-radius: 6px; border: 1px solid #d6d3d1; box-sizing: border-box; }
        .field input:focus { outline: 0; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,.2); }
        .btn { display: block; width: 100%; padding: .625rem; background: #2563eb; color: #fff; border: 0; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: .9375rem; }
        .btn:hover { background: #1d4ed8; }
        .alert-error { background: #fee2e2; color: #dc2626; padding: .625rem .875rem; border-radius: 6px; margin-bottom: 1rem; font-size: .875rem; }
        .footer { text-align: center; margin-top: 1rem; color: #a8a29e; font-size: .8125rem; }
    </style>
</head>
<body>
<div class="wrap">
    <div class="brand">
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-name">{{ site_name }}</span>
    </div>
    <div class="card">
        <h1>Sign in</h1>
        {% if error %}<div class="alert-error">{{ error }}</div>{% endif %}
        <form method="post" action="/admin/login">
            {{ csrf_field()|raw }}
            <div class="field">
                <label for="email">Email</label>
                <input id="email" name="email" type="email" required autofocus value="{{ email }}">
            </div>
            <div class="field">
                <label for="password">Password</label>
                <input id="password" name="password" type="password" required>
            </div>
            <button class="btn" type="submit">Sign in</button>
        </form>
    </div>
    <div class="footer">Pebblestack</div>
</div>
</body>
</html>
